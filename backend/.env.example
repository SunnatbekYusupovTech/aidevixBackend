# ════════════════════════════════════════════════════════════════════════════
# AIDEVIX BACKEND — Localhost uchun .env namunasi
# ────────────────────────────────────────────────────────────────────────────
# Tezda boshlash:
#   1) cp .env.example .env       (Windows: copy .env.example .env)
#   2) MONGODB_URI ni to'ldiring (local mongod yoki Atlas)
#   3) ACCESS_TOKEN_SECRET / REFRESH_TOKEN_SECRET / RESET_TOKEN_SECRET — random satr
#   4) node index.js
#
# Telegram/Bunny/Email/Payment kalitlarni bo'sh qoldirsangiz — localhost'da
# loyiha baribir ishlaydi (faqat o'sha funksiyalar ishlamaydi).
# ════════════════════════════════════════════════════════════════════════════

# ─── Server ────────────────────────────────────────────────────────────────
PORT=5000
HOST=0.0.0.0
NODE_ENV=development
LOG_LEVEL=debug

# ─── URLs ──────────────────────────────────────────────────────────────────
# Frontend manzilari (CORS uchun, vergul bilan ajrating).
# Localhost'da Next.js 3000, Vite 5173 portlarda ishlaydi.
FRONTEND_URL=http://localhost:3000,http://localhost:5173

# Backend o'z URL'i (Swagger "Try it out" + email link generatsiyasida ishlatiladi)
BACKEND_URL=http://localhost:5000

# Public sayt URL'i (Telegram newslarning "Saytga o'tish" tugmasi uchun)
SITE_URL=http://localhost:3000

# ─── Database ──────────────────────────────────────────────────────────────
# Variant A — Local MongoDB:
# MONGODB_URI=mongodb://127.0.0.1:27017/aidevix
#
# Variant B — MongoDB Atlas (tavsiya etiladi, free tier yetadi):
MONGODB_URI=mongodb+srv://username:password@cluster0.xxxxx.mongodb.net/aidevix?retryWrites=true&w=majority

# ─── JWT Secrets ───────────────────────────────────────────────────────────
# Random satr generatsiya qilish:  node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
ACCESS_TOKEN_SECRET=dev-access-secret-change-me-min-32-chars-xxxxxxxxxxxxxxxxxxxxxxxx
REFRESH_TOKEN_SECRET=dev-refresh-secret-change-me-min-32-chars-xxxxxxxxxxxxxxxxxxxxxxxx
RESET_TOKEN_SECRET=dev-reset-secret-change-me-min-32-chars-xxxxxxxxxxxxxxxxxxxxxxxxxxxx
ACCESS_TOKEN_EXPIRE=15m
REFRESH_TOKEN_EXPIRE=7d

# ─── Telegram Bot ──────────────────────────────────────────────────────────
# Localhost uchun ixtiyoriy. Bo'sh qoldirsangiz bot ishga tushmaydi,
# lekin server ishlaydi.
# Bot olish: https://t.me/BotFather → /newbot
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=your_bot_username

# Public kanal (obuna gate'i tekshiruvi shu kanalga qaratilgan)
TELEGRAM_CHANNEL_USERNAME=aidevix

# Yopiq kanal (video linklar uchun, bot a'zo bo'lishi shart)
TELEGRAM_PRIVATE_CHANNEL_USERNAME=sunnatbee_lessons

# Admin chat ID (bildirishnomalar uchun). Olish: botga /id yuboring.
TELEGRAM_ADMIN_CHAT_ID=
ADMIN_ID=

# ─── Instagram ─────────────────────────────────────────────────────────────
# Hozirda soft-check (username bo'lsa true qaytaradi) — bo'sh qoldirsa bo'ladi
INSTAGRAM_URL=https://instagram.com/aidevix
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_APP_ID=
INSTAGRAM_APP_SECRET=

# ─── Bunny.net Stream (Video) ──────────────────────────────────────────────
# Olish: https://dash.bunny.net → Stream → Library → API
# Bo'sh qoldirsa — video CRUD ishlamaydi, lekin boshqa hammasi ishlaydi.
BUNNY_STREAM_API_KEY=
BUNNY_LIBRARY_ID=
BUNNY_TOKEN_KEY=

# ─── Cloudinary (Avatar / Thumbnail upload) ────────────────────────────────
# Bo'sh qoldirsa — upload endpoint'lari xatolik qaytaradi
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ─── Email (Nodemailer) ────────────────────────────────────────────────────
# Gmail uchun: 2FA yoqing → https://myaccount.google.com/apppasswords dan app password oling
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM=Aidevix <noreply@aidevix.local>

# ─── Google Sign-In (OAuth) ────────────────────────────────────────────────
# Google Cloud Console → APIs & Services → Credentials → OAuth client ID.
# id_token'ni tekshirish uchun ruxsat etilgan barcha client ID'larni vergul bilan
# yozing (Web + Android + iOS). Mobil ilova qaysi biri orqali kirса ham audience mos keladi.
# Bo'sh qoldirsa /auth/google 500 qaytaradi (Google bilan kirish o'chiq bo'ladi).
GOOGLE_CLIENT_IDS=

# ─── Groq AI (News scheduler + AI Coach) ───────────────────────────────────
# Bepul kalit: https://console.groq.com/keys
GROQ_API_KEY=

# ─── Schedulers ────────────────────────────────────────────────────────────
# Localhost'da odatda o'chirib qo'yiladi (kanalga test post yubormaslik uchun)
NEWS_ENABLED=false
SEND_NEWS=false
CHALLENGE_SCHEDULER_ENABLED=false

# ─── Payment Gateways (Payme / Click) ──────────────────────────────────────
# Localhost'da bo'sh qoldirsa — NODE_ENV=development bo'lganda auth check by-pass qilinadi
PAYME_MERCHANT_ID=
PAYME_MERCHANT_KEY=
CLICK_SERVICE_ID=
CLICK_MERCHANT_ID=
CLICK_SECRET_KEY=

# ─── Swagger UI Auth (ixtiyoriy) ───────────────────────────────────────────
# Bo'sh qoldirsa development'da Swagger ochiq bo'ladi
SWAGGER_USERNAME=
SWAGGER_PASSWORD=

# ─── Xavfli operatsiyalar ──────────────────────────────────────────────────
# seedCourses.js'ni ishga tushirish uchun true qiling (BAZANI O'CHIRADI!)
ALLOW_DESTRUCTIVE_SEED=false
