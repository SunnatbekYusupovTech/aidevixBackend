# Server Configuration
PORT=5000
NODE_ENV=development
HOST=0.0.0.0

# Frontend URL (CORS uchun — vergul bilan bir nechta URL qo'shish mumkin)
# Development uchun: FRONTEND_URL=*  (hammaga ruxsat beradi)
# Production uchun aniq domainlar yozing:
FRONTEND_URL=https://aidevix-backend.vercel.app,http://localhost:3000,http://localhost:5173
# ⚠️ O'quvchilar Hamachi/VPN orqali ishlasa (26.x.x.x) — avtomatik ruxsat beriladi
# ⚠️ Private network IPs (192.168.x.x, 10.x.x.x, localhost) — avtomatik ruxsat beriladi

# Backend URL (Swagger "Try it out" uchun — o'z domainini ruxsat berish)
BACKEND_URL=https://your-backend.up.railway.app

# Database
MONGODB_URI=mongodb+srv://username:password@cluster0.xxxxx.mongodb.net/aidevix?retryWrites=true&w=majority&appName=Cluster0

# Redis (Upstash recommended) — distributed rate limiting across Railway replicas.
# Without this, counters live in process memory and effective limits multiply by replica count.
# Free tier is enough; format: rediss://default:<password>@<region>.upstash.io:6379
REDIS_URL=

# JWT Secrets (Production'da kuchli secret'lar ishlating!)
ACCESS_TOKEN_SECRET=your-super-secret-access-token-key-change-this-in-production-min-32-chars
REFRESH_TOKEN_SECRET=your-super-secret-refresh-token-key-change-this-in-production-min-32-chars
RESET_TOKEN_SECRET=your-super-secret-reset-token-key-change-this-in-production-min-32-chars
CSRF_SECRET=your-super-secret-csrf-token-key-change-this-in-production-min-32-chars
ACCESS_TOKEN_EXPIRE=15m
REFRESH_TOKEN_EXPIRE=7d

# Google OAuth (Google Cloud Console → Credentials → OAuth 2.0 Client ID)
# https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# Telegram Configuration
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
# Obuna tekshiruvi uchun kanal (public)
TELEGRAM_CHANNEL_USERNAME=aidevix
# Video linklar uchun yopiq kanal (private)
TELEGRAM_PRIVATE_CHANNEL_USERNAME=sunnatbee_lessons

# Instagram Configuration (if using Instagram API)
INSTAGRAM_ACCESS_TOKEN=your-instagram-access-token
INSTAGRAM_APP_ID=your-instagram-app-id
INSTAGRAM_APP_SECRET=your-instagram-app-secret

# Swagger UI Authentication (Optional)
SWAGGER_USERNAME=admin
SWAGGER_PASSWORD=your_strong_password_here

# Email (Nodemailer — xush kelibsiz, sertifikat xabarlari)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-gmail-app-password
EMAIL_FROM=Aidevix <noreply@aidevix.com>

# Vercel Blob (Avatar va thumbnail yuklash) — Cloudinary UZ da ishlamaydi
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxx   # Vercel dashboard -> Storage -> Blob

# ─── Bunny.net — VIDEO (Stream, backend bunny.js bilan) ───────────────────────
# Loyiha videolarni Bunny STREAM orqali uzatadi (iframe.mediadelivery.net).
# Storage + o‘zingiz yaratgan Pull Zone (masalan aidevix.b-cdn.net) alohida;
# ular hozircha backend kodida ishlatilmaydi.
#
# Olish joyi: https://dash.bunny.net → Stream → <Library nomi> → API
#   BUNNY_STREAM_API_KEY = sahifadagi "API Key" (Copy)
#   BUNNY_LIBRARY_ID     = "Video Library ID" (raqam)
# Token: shu library → Security → Token Authentication → kalitni yoqing va
#   ko‘rsatilgan "Token authentication key" ni BUNNY_TOKEN_KEY ga yozing.
#
BUNNY_STREAM_API_KEY=PASTE_STREAM_API_KEY_HERE
BUNNY_LIBRARY_ID=643144
BUNNY_TOKEN_KEY=PASTE_TOKEN_AUTHENTICATION_KEY_HERE
#
# Ixtiyoriy (hozirgi backend o‘qimaydi): faqat hujjat / kelajak uchun
# BUNNY_STORAGE_CDN_BASE=https://aidevix.b-cdn.net

# Payment Gateways
PAYME_MERCHANT_ID=your-payme-merchant-id
PAYME_SECRET_KEY=your-payme-secret-key
CLICK_SERVICE_ID=your-click-service-id
CLICK_MERCHANT_ID=your-click-merchant-id
CLICK_SECRET_KEY=your-click-secret-key

# Telegram Bot Webhook (Foydalanuvchilar /start yuborganda chatId saqlash uchun)
# Long Polling ishlatiladi — webhook shart emas
# TELEGRAM_BOT_WEBHOOK_URL=https://your-backend.up.railway.app/api/telegram/webhook

# Admin bildirishnomalar uchun chat/guruh ID
# Botni admin guruhga qo'shing, keyin /id buyrug'ini yuboring
TELEGRAM_ADMIN_CHAT_ID=your-admin-chat-id

# News Scheduler (Kunlik IT/AI yangiliklar kanalga yuborish)
NEWS_ENABLED=false
SEND_NEWS=false
GROQ_API_KEY=your-groq-api-key
ADMIN_ID=your-telegram-admin-id

# ─── Auth Hardening (ASVS L2) ────────────────────────────────────────────────
# HaveIBeenPwned password breach check (NIST 800-63B). Set HIBP_ENABLED=false to
# disable the check entirely (e.g., for offline / regional deployments).
HIBP_ENABLED=true

# CAPTCHA — bot protection on register/login/forgot-password (ASVS V11.1.3).
# Provider: 'turnstile' (Cloudflare, free, recommended) or 'hcaptcha'.
# Leave both unset to disable CAPTCHA gating.
CAPTCHA_PROVIDER=
CAPTCHA_SECRET=
# Front-end also needs the public site key:
# NEXT_PUBLIC_TURNSTILE_SITE_KEY=...  or  NEXT_PUBLIC_HCAPTCHA_SITE_KEY=...

# Trust proxy hop count — Railway/Render typically use 1 layer. Adjust if behind a
# different reverse proxy chain. Setting `true` enables IP spoofing via X-Forwarded-For.
TRUST_PROXY=1

# Auth debug — verbose token-issuance/refresh logs in dev. Never enable in production.
AUTH_DEBUG=false
