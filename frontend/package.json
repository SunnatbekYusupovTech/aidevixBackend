{
  "name": "aidevix-frontend",
  "version": "1.0.0",
  "description": "Aidevix - Online kurs platformasi frontend (React + Tailwind + DaisyUI + Redux + GSAP)",
  "license": "UNLICENSED",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test:e2e": "npx playwright test",
    "test:e2e:ui": "npx playwright test --ui",
    "test:e2e:headed": "npx playwright test --headed",
    "test:e2e:chromium": "npx playwright test --project=chromium",
    "test:e2e:firefox": "npx playwright test --project=firefox",
    "test:e2e:webkit": "npx playwright test --project=webkit",
    "test:e2e:mobile": "npx playwright test --project=mobile-chrome --project=mobile-safari",
    "test:e2e:report": "npx playwright show-report e2e/playwright-report",
    "test:e2e:debug": "npx playwright test --debug"
  },
  "dependencies": {
    "@monaco-editor/react": "^4.7.0",
    "@react-oauth/google": "^0.13.5",
    "@reduxjs/toolkit": "^2.12.0",
    "@sankyu/react-circle-flags": "^1.6.7",
    "@sentry/nextjs": "^10.67.0",
    "axios": "^1.18.1",
    "clsx": "^2.1.1",
    "dayjs": "^1.11.21",
    "framer-motion": "^11.3.19",
    "gsap": "^3.15.0",
    "lenis": "^1.3.25",
    "next": "^14.2.35",
    "react": "^18.2.0",
    "react-confetti": "^6.4.0",
    "react-dom": "^18.2.0",
    "react-hook-form": "^7.82.0",
    "react-hot-toast": "^2.4.1",
    "react-icons": "^5.7.0",
    "react-redux": "^9.3.0",
    "recharts": "^3.10.0",
    "swiper": "^12.2.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "autoprefixer": "^10.5.4",
    "daisyui": "^4.12.10",
    "eslint": "^8",
    "eslint-config-next": "^14.2.35",
    "eslint-plugin-react": "^7.35.0",
    "eslint-plugin-react-hooks": "^5.1.0-rc.0",
    "eslint-plugin-react-refresh": "^0.5.3",
    "postcss": "^8.5.21",
    "tailwindcss": "^3.4.10",
    "typescript": "^5"
  }
}
